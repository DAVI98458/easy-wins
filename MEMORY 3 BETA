local GasTab = Window:CreateTab("JerryCans Teleports", 4483362458)

-- Função para teleportar temporariamente e acionar ClickDetectors
local function teleportAndClick(target)
    if not target then return end

    -- Determina CFrame seguro
    local targetCFrame
    if target:IsA("BasePart") then
        targetCFrame = target.CFrame
    elseif target:IsA("Model") then
        targetCFrame = target.PrimaryPart and target.PrimaryPart.CFrame or target:FindFirstChildWhichIsA("BasePart") and target:FindFirstChildWhichIsA("BasePart").CFrame
    end
    if not targetCFrame then return end

    local originalCFrame = hrp.CFrame

    -- Teleporta para JerryCan
    hrp.CFrame = targetCFrame + Vector3.new(0,2,0)

    -- Aguarda 1 segundo
    task.wait(0.5)

    -- Aciona todos ClickDetectors descendentes
    for _, detector in ipairs(target:GetDescendants()) do
        if detector:IsA("ClickDetector") then
            pcall(function() fireclickdetector(detector) end)
        end
    end

    -- Aguarda mais 1 segundo
    task.wait(0.1)

    -- Retorna à posição original
    hrp.CFrame = originalCFrame
end

-- Função para pegar JerryCan seguro
local function getJerryCan(n)
    local jc = workspace:FindFirstChild("JerryCans")
    if not jc then return nil end
    return jc:GetChildren()[n]
end

