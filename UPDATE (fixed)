    local start = tick()
    local stop = start + durationSeconds
    while tick() < stop do
        local frac = math.clamp((tick() - start) / durationSeconds, 0, 1)
        percentLabel.Text = tostring(math.floor(frac * 100)) .. "%"
        task.wait(0.1)
    end
