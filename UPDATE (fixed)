    percentLabel.Font = Enum.Font.SourceSansSemibold
    percentLabel.TextColor3 = Color3.new(1,1,1)
    percentLabel.TextScaled = true
    percentLabel.Text = "0%"

    -- Tween o preenchimento ao longo do tempo (suave)
    local tweenInfo = TweenInfo.new(durationSeconds, Enum.EasingStyle.Linear, Enum.EasingDirection.Out)
    local tween = TweenService:Create(barFill, tweenInfo, {Size = UDim2.new(1, 0, 1, 0)})
    tween:Play()

