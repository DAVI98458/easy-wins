-- Script para executor: teleporte + múltiplos fallbacks + highlight vermelho automático
-- Cole no executor (client). Verifique o console (F9) para logs detalhados.

local Players = game:GetService("Players")
local player = Players.LocalPlayer

-- Segurança: espera o personagem
local function waitChar()
    local ch = player.Character or player.CharacterAdded:Wait()
    local root = ch:WaitForChild("HumanoidRootPart", 5)
    return ch, root
end

-- Cria GUI no CoreGui (executor)
local gui = Instance.new("ScreenGui")
gui.Name = "GetAmoGUI"
gui.Parent = game.CoreGui

local button = Instance.new("TextButton")
button.Size = UDim2.new(0, 120, 0, 40)
button.Position = UDim2.new(1, -130, 0, 10)
button.AnchorPoint = Vector2.new(0, 0)
button.BackgroundColor3 = Color3.fromRGB(60,180,75)
button.TextColor3 = Color3.new(1,1,1)
button.Font = Enum.Font.SourceSansBold
button.TextSize = 20
button.Text = "get ammo"
button.Active = true
button.Draggable = true
button.Parent = gui

-- Posições de teleporte
local teleportPositions = {
    Vector3.new(-45, 4, -66),
    Vector3.new(52, 4, 283),
    Vector3.new(95, 4, 179),
    Vector3.new(-7, 4, -150)
}

-- Funções utilitárias
local function log(...) print("[GETAMO]", ...) end
local function warnlog(...) warn("[GETAMO] ", ...) end

-- Detectar função do exploit
local function detectFireFunctions()
    local candidates = {
        "fireclickdetector", "clickdetectorfire", "fireClickDetector",
        "FireClickDetector", "fireclickdetector_internal", "fireclickdetectorremote",
        "FireClickDetectorInternal"
    }
    for _, name in ipairs(candidates) do
        local f = rawget(_G, name)
        if type(f) == "function" then
            log("Encontrada função exploit:", name)
            return f
        end
    end
    return rawget(_G, "fireclickdetector")
end

local availableFire = detectFireFunctions()
if not availableFire then
    log("Nenhuma função 'fireclickdetector' detectada automaticamente.")
end

-- Tenta clicar em um ClickDetector
local function tryFireDetector(detector)
    if not detector or not detector:IsA("ClickDetector") then
        return false
    end

    if availableFire then
        local ok = pcall(function() availableFire(detector) end)
        if ok then
            return true
        end
    end

    local gc = getconnections
    if typeof(gc) == "function" then
        local conns = gc(detector.MouseClick)
        if conns and #conns > 0 then
            for _, c in ipairs(conns) do
                if c.Function then
                    pcall(c.Function, player)
                elseif c.Fire then
                    pcall(c.Fire, c, player)
                end
            end
            return true
        end
    end
    return false
end

-- Coletar detectors
local function collectDetectors()
    local a = workspace:FindFirstChild("AmmoPiles")
    if not a then return {} end
    local detectors = {}

    local children = a:GetChildren()
    if children[4] and children[4]:FindFirstChild("Detector") then
        table.insert(detectors, children[4].Detector:FindFirstChildOfClass("ClickDetector"))
    end
    if children[3] and children[3]:FindFirstChild("Detector") then
        table.insert(detectors, children[3].Detector:FindFirstChildOfClass("ClickDetector"))
    end
    if a:FindFirstChild("LeftAmmoPile") and a.LeftAmmoPile:FindFirstChild("Detector") then
        table.insert(detectors, a.LeftAmmoPile.Detector:FindFirstChildOfClass("ClickDetector"))
    end
    if a:FindFirstChild("RightAmmoPile") and a.RightAmmoPile:FindFirstChild("Detector") then
        table.insert(detectors, a.RightAmmoPile.Detector:FindFirstChildOfClass("ClickDetector"))
    end

    local valid = {}
    for _, d in ipairs(detectors) do
        if d and d:IsA("ClickDetector") then
            table.insert(valid, d)
            log("Detector:", d:GetFullName())
        end
    end
    return valid
end

-- Acionar todos os detectors por 'duration' segundos
local function fireAllFor(detectors, duration)
    local t0 = tick()
    while tick() - t0 < duration do
        for _, d in ipairs(detectors) do
            tryFireDetector(d)
        end
        task.wait(0.1)
    end
end

-- Botão principal
button.MouseButton1Click:Connect(function()
    button.Active = false
    button.Draggable = false

    local ch, root = waitChar()
    local original = root.CFrame
    local detectors = collectDetectors()
    if #detectors == 0 then
        warnlog("Nenhum detector encontrado.")
        button.Active = true
        button.Draggable = true
        return
    end

    for idx, pos in ipairs(teleportPositions) do
        root.CFrame = CFrame.new(pos + Vector3.new(0, 3, 0))
        log("Teleportando para", pos)
        task.spawn(function()
            fireAllFor(detectors, 5)
        end)
        task.wait(0.3)
    end

    task.wait(0.2)
    root.CFrame = original
    button.Active = true
    button.Draggable = true
    log("Sequência finalizada e jogador retornado à posição original.")
end)

