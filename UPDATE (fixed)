-- ======= Helpers de UI minimal (somente whitelist e Head spawned) =======
local function showCenterMessage(text, duration, bgColor, textColor)
    duration = duration or 3
    bgColor = bgColor or Color3.fromRGB(30,30,30)
    textColor = textColor or Color3.new(1,1,1)

    local screen = Instance.new("ScreenGui")
    screen.Name = "GetAmo_Message"
    screen.ResetOnSpawn = false
    screen.Parent = game.CoreGui

    local frame = Instance.new("Frame", screen)
    frame.Size = UDim2.new(0.5, 0, 0.14, 0)
    frame.Position = UDim2.new(0.5, 0, 0.5, 0)
    frame.AnchorPoint = Vector2.new(0.5, 0.5)
    frame.BackgroundColor3 = bgColor
    frame.BackgroundTransparency = 0.35
    frame.BorderSizePixel = 0

    local label = Instance.new("TextLabel", frame)
    label.Size = UDim2.new(1, -8, 1, -8)
    label.Position = UDim2.new(0, 4, 0, 4)
    label.BackgroundTransparency = 1
    label.Text = tostring(text)
    label.TextColor3 = textColor
    label.Font = Enum.Font.SourceSansBold
    label.TextSize = 20
    label.TextWrapped = true
    label.TextScaled = true
    label.TextTransparency = 1

    -- fade in
    local steps = 10
    for i = 1, steps do
        local a = i/steps
        label.TextTransparency = 1 - a
        frame.BackgroundTransparency = 0.35 * (1 - a)
        task.wait(0.02)
    end

    task.delay(duration, function()
        for i = 1, steps do
            local a = i/steps
            label.TextTransparency = a
            frame.BackgroundTransparency = 0.35 * a
            task.wait(0.02)
        end
        pcall(function() screen:Destroy() end)
    end)
end

local function playAlertSound(duration)
    duration = duration or 3
    local sound = Instance.new("Sound")
    sound.SoundId = "rbxassetid://138087386" -- alerta genérico (troque se quiser)
    sound.Volume = 1
    sound.Looped = false
    sound.Parent = game.CoreGui
    pcall(function() sound:Play() end)
    task.delay(duration, function()
        pcall(function() sound:Stop(); sound:Destroy() end)
    end)
end

-- ======= Whitelist check (apenas mensagens de whitelist) =======
local function isWhitelisted(name)
    for _, v in ipairs(WHITELIST) do
        if v == name then return true end
    end
    return false
end

