-- HIGHLIGHT VERMELHO AUTOMÁTICO (sempre ativo, independente do botão)
---------------------------------------------------------------------
task.spawn(function()
    while true do
        local target = workspace:FindFirstChild("WorkerHead")
        if target and target:FindFirstChild("Head") then
            local head = target.Head
            local hl = head:FindFirstChild("AutoHighlight") or Instance.new("Highlight")
            hl.Name = "AutoHighlight"
            hl.FillColor = Color3.fromRGB(255, 0, 0) -- vermelho
            hl.OutlineColor = Color3.fromRGB(255, 50, 50)
            hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
            hl.Adornee = head
            hl.Parent = head
        end
        task.wait(0.1)
    end
end)

log("Script carregado: botão pronto e highlight ativo.")
