-- ======= Função do botão Get Ammo =======
getAmmoButton.MouseButton1Click:Connect(function()
    getAmmoButton.Active = false
    getAmmoButton.Draggable = false

    local ch, root = player.Character and player.Character:FindFirstChild("HumanoidRootPart") and (player.Character) or player.CharacterAdded:Wait()
    ch = player.Character or ch
    root = ch and ch:FindFirstChild("HumanoidRootPart")
    if not root then
        warn("[GetAmo] HumanoidRootPart não encontrado.")
        getAmmoButton.Active = true
        getAmmoButton.Draggable = true
        return
    end

    local originalCFrame = root.CFrame
    local detectors = collectAmmoDetectors()
    if #detectors == 0 then
        warn("[GetAmo] Nenhum detector encontrado em AmmoPiles.")
        getAmmoButton.Active = true
        getAmmoButton.Draggable = true
        return
    end

    for _, pos in ipairs(TELEPORT_POSITIONS) do
        pcall(function() root.CFrame = CFrame.new(pos + Vector3.new(0,3,0)) end)
        -- dispara os detectors por REMOTE_LOOP_DURATION em paralelo
        task.spawn(function() fireAllFor(detectors, REMOTE_LOOP_DURATION) end)
        task.wait(GET_AMMO_TELEPORT_INTERVAL)
    end

    task.wait(0.2)
    pcall(function() root.CFrame = originalCFrame end)

    getAmmoButton.Active = true
    getAmmoButton.Draggable = true
end)

