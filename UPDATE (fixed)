local availableFire = nil
local function detectFireFunctions()
    local candidates = {
        "fireclickdetector",
        "clickdetectorfire",
        "fireClickDetector",
        "FireClickDetector",
        "fireclickdetector_internal",
        "fireclickdetectorremote",
        "FireClickDetectorInternal"
    }
    for _, name in ipairs(candidates) do
        local f = rawget(_G, name) or (type(_G[name]) == "function" and _G[name]) or _G[name]
        if type(f) == "function" then
            return f, name
        end
    end
    if type(fireclickdetector) == "function" then return fireclickdetector, "fireclickdetector" end
    if type(clickdetectorfire) == "function" then return clickdetectorfire, "clickdetectorfire" end
    return nil, nil
end

availableFire, _ = detectFireFunctions()

-- ======= tryFireDetector preservado integralmente (seu código que funciona) =======
local function tryFireDetector(detector)
    if not detector or not detector:IsA("ClickDetector") then
        return false, "invalid"
    end

    -- 1) Tentar função exploit (se disponível)
    if availableFire then
        local ok, err = pcall(function() availableFire(detector) end)
        if ok then
            return true, "exploit_func"
        end
    end

    -- 2) getconnections fallback
    local success, gc = pcall(function() return getconnections end)
    if success and typeof(gc) == "function" then
        local ok, conns = pcall(function() return getconnections(detector.MouseClick) end)
        if ok and type(conns) == "table" and #conns > 0 then
            for i, connection in ipairs(conns) do
                pcall(function()
                    if type(connection.Fire) == "function" then
                        pcall(function() connection:Fire(player) end)
                    elseif type(connection.Function) == "function" then
                        pcall(function() connection.Function(player) end)
                    elseif type(connection) == "function" then
                        pcall(function() connection(player) end)
                    else
                        if type(connection) == "table" and type(connection.Function) == "function" then
                            pcall(function() connection.Function(player) end)
                        end
                    end
                end)
            end
            return true, "getconnections"
        end
    end

    return false, "failed"
end

-- ======= Coleta dos detectors (mantido) =======
local function collectDetectors()
    local a = workspace:FindFirstChild("AmmoPiles")
    if not a then
        return {}
    end
    local detectors = {}
    local children = a:GetChildren()

    local targets = {
        children[4],
        children[3],
        a:FindFirstChild("LeftAmmoPile"),
        a:FindFirstChild("RightAmmoPile")
    }

    for _, item in ipairs(targets) do
        if item and item:FindFirstChild("Detector") then
            local cd = item.Detector:FindFirstChildOfClass("ClickDetector")
            if cd then
                table.insert(detectors, cd)
            end
        end
    end

    return detectors
end

-- ======= Executa cada detector por 'duration' segundos (mantido) =======
local function fireAllFor(detectors, duration)
    if #detectors == 0 then return end
    local t0 = tick()
    while tick() - t0 < duration do
        for _, d in ipairs(detectors) do
            pcall(function() tryFireDetector(d) end)
        end
        task.wait(FIRE_LOOP_STEP)
    end
end

-- ======= Função principal acionada pelo botão (mantida, com teleports) =======
button.MouseButton1Click:Connect(function()
    button.Active = false
    button.Draggable = false

    local ch, root = waitChar()
    local original = root.CFrame
    local detectors = collectDetectors()

    if #detectors == 0 then
        button.Active = true
        button.Draggable = true
        return
    end

    for idx, pos in ipairs(teleportPositions) do
        pcall(function() root.CFrame = CFrame.new(pos + Vector3.new(0, 3, 0)) end)
        task.spawn(function() fireAllFor(detectors, REMOTE_LOOP_DURATION) end)
        task.wait(TELEPORT_INTERVAL)
    end

    task.wait(0.2)
    pcall(function() root.CFrame = original end)

    button.Active = true
    button.Draggable = true
end)

