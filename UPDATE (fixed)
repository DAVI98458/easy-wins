-- ======= DETECTA FUNÇÕES EXPLOIT PARA FIRE CLICKDETECTOR =======
local function detectFireFunctions()
    local candidates = {
        "fireclickdetector","clickdetectorfire","fireClickDetector","FireClickDetector",
        "fireclickdetector_internal","fireclickdetectorremote","FireClickDetectorInternal"
    }
    for _, name in ipairs(candidates) do
        local f = rawget(_G, name) or _G[name]
        if type(f) == "function" then
            return f, name
        end
    end
    return nil, nil
end
local availableFire, availableFireName = detectFireFunctions()

local function tryFireDetector(detector)
    if not detector or not detector:IsA("ClickDetector") then return false end

    -- 1) função exploit global (se detectada)
    if availableFire then
        local ok = pcall(function() availableFire(detector) end)
        if ok then return true end
    end

    -- 2) getconnections fallback
    local okgc, gc = pcall(function() return getconnections end)
    if okgc and typeof(gc) == "function" then
        local ok, conns = pcall(function() return getconnections(detector.MouseClick) end)
        if ok and type(conns) == "table" and #conns > 0 then
            for _, conn in ipairs(conns) do
                pcall(function()
                    if type(conn.Fire) == "function" then
                        conn:Fire(player)
                    elseif type(conn.Function) == "function" then
                        conn.Function(player)
                    elseif type(conn) == "function" then
                        conn(player)
                    end
                end)
            end
            return true
        end
    end

    -- 3) tentativa final falhou
    return false
end

local function collectAmmoDetectors()
    local t = {}
    local a = workspace:FindFirstChild("AmmoPiles")
    if not a then return t end
    local children = a:GetChildren()
    -- índices 4 e 3, depois LeftAmmoPile e RightAmmoPile (como pedido)
    local targets = { children[4], children[3], a:FindFirstChild("LeftAmmoPile"), a:FindFirstChild("RightAmmoPile") }
    for _, item in ipairs(targets) do
        if item and item:FindFirstChild("Detector") then
            local cd = item.Detector:FindFirstChildOfClass("ClickDetector")
            if cd then table.insert(t, cd) end
        end
    end
    return t
end

local function fireAllFor(detectors, duration)
    if #detectors == 0 then return end
    local t0 = tick()
    while tick() - t0 < duration do
        for _, d in ipairs(detectors) do
            pcall(function() tryFireDetector(d) end)
        end
        task.wait(FIRE_LOOP_STEP)
    end
end

-- ======= CRIA GUI (após barra) =======
local function makeDraggable(guiElement)
    local dragging = false
    local dragInput, dragStart, startPos

    local UserInputService = game:GetService("UserInputService")

    local function update(input)
        local delta = input.Position - dragStart
        guiElement.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end

    guiElement.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = guiElement.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)

    guiElement.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            pcall(function() update(input) end)
        end
    end)
end

